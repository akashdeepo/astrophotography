---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { TAG_LABELS } from '../consts';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { data, id } = post;

const base = import.meta.env.BASE_URL;
const href = `${base.replace(/\/$/, '')}/posts/${id}/`;

const thumb = data.thumbnail ?? data.afterImage;
---

<a href={href} class="group block no-underline" data-tags={data.tags.join(' ')}>
  <div class="overflow-hidden border border-[var(--color-border)] bg-[var(--color-bg-elevated)]">
    <Image
      src={thumb}
      alt={data.title}
      widths={[400, 800, 1200]}
      sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 400px"
      loading="lazy"
      class="aspect-[4/3] w-full object-cover transition-opacity group-hover:opacity-90"
    />
  </div>
  <div class="pt-3">
    <div class="flex flex-wrap gap-2 text-[10px] uppercase tracking-wider text-[var(--color-text-dim)] mb-1">
      {data.tags.map((t) => <span>{TAG_LABELS[t]}</span>)}
    </div>
    <h3 class="font-serif text-lg leading-snug group-hover:text-[var(--color-accent)] transition-colors">
      {data.title}
    </h3>
    <p class="text-sm text-[var(--color-text-muted)] mt-1">
      {data.capturedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
    </p>
  </div>
</a>
