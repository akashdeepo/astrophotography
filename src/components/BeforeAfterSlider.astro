---
// Thin wrapper around the img-comparison-slider web component.
// The custom element is registered via a client-side script block below,
// which Astro bundles automatically as an ES module.
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  before: ImageMetadata;
  after: ImageMetadata;
  beforeLabel?: string;
  afterLabel?: string;
}

const { before, after, beforeLabel = 'Before', afterLabel = 'After' } = Astro.props;
---

<div class="relative">
  <img-comparison-slider>
    <Image
      slot="first"
      src={before}
      alt={beforeLabel}
      widths={[800, 1200, 1600, 2000]}
      sizes="(max-width: 1024px) 100vw, 960px"
      loading="eager"
    />
    <Image
      slot="second"
      src={after}
      alt={afterLabel}
      widths={[800, 1200, 1600, 2000]}
      sizes="(max-width: 1024px) 100vw, 960px"
      loading="eager"
    />
  </img-comparison-slider>
  <span
    class="absolute top-2 left-2 text-[10px] uppercase tracking-widest font-mono bg-black/70 text-white px-2 py-1 pointer-events-none"
  >
    {beforeLabel}
  </span>
  <span
    class="absolute top-2 right-2 text-[10px] uppercase tracking-widest font-mono bg-black/70 text-white px-2 py-1 pointer-events-none"
  >
    {afterLabel}
  </span>
</div>

<script>
  import 'img-comparison-slider';
</script>
